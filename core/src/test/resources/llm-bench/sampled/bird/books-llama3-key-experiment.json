{
    "name": "books-{{QN}} llama3-key Experiment",
    "metrics": [
        "CellPrecisionFilteredAttributes",
        "CellSimilarityPrecisionFilteredAttributes",
        "CellRecallFilteredAttributes",
        "CellSimilarityRecallFilteredAttributes",
        "CellF1ScoreFilteredAttributes",
        "CellSimilarityF1ScoreFilteredAttributes",
        "TupleCardinality",
        "TupleConstraintFilteredAttributes",
        "TupleSimilarityConstraintFilteredAttributes",
        "TupleCellSimilarityFilteredAttributes"
    ],
    "dbms": "postgres",
    "operatorsConfig": {
        "scan": {
            "queryExecutor": "togetherai-llama3-key",
            "maxIterations": 1
        }
    },
    "query": {
        "sql": "{{QUERY_SQL}}",
        "schema": {
            "name": "books_sample",
            "schema": "target",
            "username": "pguser",
            "password": "pguser",
            "tables": [
                {
                    "tableName": "book",
                    "attributes": [
                        {
                            "name": "title",
                            "type": "STRING",
                            "key": true
                        },
                        {
                            "name": "isbn13",
                            "type": "STRING",
                            "nullable": true
                        },
                        {
                            "name": "num_pages",
                            "type": "STRING",
                            "nullable": true
                        },
                        {
                            "name": "publication_date",
                            "type": "STRING",
                            "nullable": true
                        }
                    ]
                }
            ]
        },
        "results": "/llm-bench/sampled/bird/books"
    }
}